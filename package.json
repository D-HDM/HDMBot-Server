{
  "name": "hdm-whatsapp-bot",
  "version": "2.0.0",
  "description": "HDM BOT - Multi-Session WhatsApp Bot with REST API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "client": "node whatsapp/client.js",
    "admin": "node scripts/admin.js",
    "check-session": "node -e \"require('./scripts/dnsSet');const m=require('mongoose');m.connect(process.env.MONGODB_URI||'mongodb://localhost:27017/hdm-bot').then(async()=>{const s=await m.connection.db.collection('sessions').findOne({sessionId:process.env.SESSION_ID||'HDM-BOT-SESSION'});console.log(s?`✅ ${s.status} | creds:${Object.keys(s.creds||{}).length} | 📱${s.metadata?.phoneNumber||'N/A'}`:'❌ No session');await m.disconnect();process.exit()}).catch(e=>{console.error(e.message);process.exit(1)})"
  },
  "keywords": ["whatsapp", "bot", "baileys", "hdm", "multi-session"],
  "author": "Davix HDM",
  "license": "MIT",
  "dependencies": {
    "@whiskeysockets/baileys": "^6.6.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "form-data": "^4.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.6.3",
    "pino": "^8.16.1",
    "pino-pretty": "^10.2.3",
    "qrcode": "^1.5.3",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.33.0",
    "socket.io": "^4.7.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}